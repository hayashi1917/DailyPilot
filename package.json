{
  "name": "daily-pilot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev public --d1 DB=daily-pilot",
    "deploy": "wrangler pages deploy public --project-name daily-pilot",
    "check": "node --check public/app.js && node --check functions/api/[[path]].js",
    "db:migrate:local": "wrangler d1 migrations apply daily-pilot --local",
    "db:migrate:prod": "wrangler d1 migrations apply daily-pilot --remote"
  }
}
